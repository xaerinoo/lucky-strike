generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id        BigInt   @id @default(autoincrement())
  ltShpId   String   @unique
  name      String
  address   String
  region1   String
  region2   String
  lat       Float
  lng       Float
  wins      Win[]
  createdAt DateTime @default(now())
}

model Win {
  id        BigInt   @id @default(autoincrement())
  storeId   BigInt
  round     Int
  rank      Int
  store     Store    @relation(fields: [storeId], references: [id])
  createdAt DateTime @default(now())
}